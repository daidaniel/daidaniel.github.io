---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import keyboard from '../assets/qk65.png';

const description =
  'Daniel Dai is a software engineer at Apple building AI-powered internal tooling. Previously at TikTok. UCLA computer science alum.';
---

<Base title="Daniel Dai — Software Engineer" description={description}>
  <figure class="motion-safe:animate-fade-up">
    <Image
      src={keyboard}
      alt="QK65 mechanical keyboard with white keycaps"
      widths={[480, 768, 1152, 1536]}
      sizes="(max-width: 45rem) calc(100vw - 3rem), 39rem"
      loading="eager"
      fetchpriority="high"
    />
  </figure>
  <h1 class="mt-10 text-[clamp(2.5rem,2rem_+_2.5vw,3.5rem)] font-semibold leading-[1.1] tracking-[-0.02em] motion-safe:animate-fade-up [animation-delay:100ms]">
    Daniel Dai
  </h1>
  <p class="mt-3 text-lg leading-[1.7] text-zinc-400 motion-safe:animate-fade-up [animation-delay:175ms]">Software engineer at Apple</p>
  <p class="mt-6 text-pretty text-zinc-300 motion-safe:animate-fade-up [animation-delay:250ms]">
    I build software across the stack—from AI-powered internal tools at Apple to
    Go microservices at TikTok serving millions of users. UCLA computer science
    alum, currently pursuing a master's at UIUC, with a passion for building
    simple, reliable software—and optimizing everything from developer workflows
    to custom keyboards.
  </p>
  <ul class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-4 sm:gap-x-7 motion-safe:animate-fade-up [animation-delay:325ms]" role="list">
    <li>
      <a
        class="inline-block rounded bg-amber-300 px-5 py-2 font-semibold text-zinc-950 transition hover:-translate-y-0.5 hover:bg-amber-500 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-amber-300 active:translate-y-0 sm:px-6"
        href="/DanielDai-Resume.pdf">Résumé</a
      >
    </li>
    <li>
      <a
        class="text-amber-300 underline-offset-[0.25em] transition-colors hover:underline focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-amber-300"
        href="https://github.com/daidaniel">GitHub</a
      >
    </li>
    <li>
      <a
        class="text-amber-300 underline-offset-[0.25em] transition-colors hover:underline focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-amber-300"
        href="https://www.linkedin.com/in/daidaniel">LinkedIn</a
      >
    </li>
    <li>
      <a
        class="text-amber-300 underline-offset-[0.25em] transition-colors hover:underline focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-amber-300"
        href="mailto:danieldaiw@gmail.com">Email</a
      >
    </li>
  </ul>
</Base>
