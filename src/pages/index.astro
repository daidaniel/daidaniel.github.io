---
import { Image } from "astro:assets";
import Section from "../components/Section.astro";
import TextLink from "../components/TextLink.astro";
import Base from "../layouts/Base.astro";
import keyboard from "../assets/keyboard.svg";
import shadow from "../assets/shadow.svg";

const description =
  "Daniel Dai is a software engineer at Apple building AI-powered internal tooling. Previously at TikTok. UCLA computer science alum.";
---

<Base title="Daniel Dai — Software Engineer" description={description}>
  <Section>
    <!-- Below sm the keyboard keeps the size it has at the sm boundary (592px =
       640px viewport minus px-6) — a design choice to stay large — and the
       figure clips its right side. The -mr-6 bleeds the clip edge through
       the Section container's right padding to the viewport edge. The mb calc cancels the
       transparent band under the keyboard's diagonal bottom edge (slope 1/3):
       band = 152px - width/3 (width = content width; the visible clip is
       width + 24px bleed), gone once the full keyboard fits. -->
    <figure
      class="relative max-sm:-mr-6 max-sm:mb-[min(0px,33.333%_-_152px)] max-sm:overflow-x-clip md:translate-x-6 motion-safe:animate-fade-up"
    >
      <!-- The shadow SVG's canvas (2196×1106) is larger than the keyboard's
         (1979×1017) because it contains the baked long shadow; their
         bottom-left corners coincide, so anchor bottom-left and scale the
         width by 2196/1979 to keep both SVGs at equal units-per-pixel. -->
      <img
        class="absolute bottom-0 left-0 w-[calc(592px*2196/1979)] max-w-none sm:w-[calc(100%*2196/1979)]"
        src={shadow.src}
        alt=""
      />
      <Image
        class="relative w-[592px] max-w-none sm:w-full"
        src={keyboard}
        alt="QK65 mechanical keyboard with white keycaps"
        loading="eager"
        fetchpriority="high"
      />
    </figure>
    <div class="md:-translate-x-6">
      <h1
        class="type-out mt-12 text-[2.5rem] font-semibold leading-[1.1] [--type-chars:10] sm:text-[3rem] md:text-[3.5rem]"
      >
        Daniel Dai
      </h1>
      <p class="mt-3 text-lg leading-[1.7] text-zinc-400 [animation-delay:175ms] motion-safe:animate-fade-up">
        Software engineer at Apple
      </p>
      <p class="mt-6 text-pretty text-zinc-300 [animation-delay:250ms] motion-safe:animate-fade-up">
        I build software across the stack, from AI-powered internal tools at Apple to backend microservices at TikTok
        serving millions of users. UCLA computer science alum, currently pursuing a master's at UIUC, with a passion for
        building simple, reliable software—and optimizing everything from developer workflows to custom keyboards.
      </p>
      <ul
        class="flex flex-wrap items-center gap-4 mt-8 [animation-delay:325ms] sm:gap-x-7 motion-safe:animate-fade-up"
        role="list"
      >
        <li>
          <a
            class="inline-block px-5 py-2 font-semibold text-zinc-950 rounded bg-amber-300 transition sm:px-6 hover:-translate-y-0.5 hover:bg-amber-500 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-amber-300 active:translate-y-0"
            href="/DanielDai-Resume.pdf">Résumé</a
          >
        </li>
        <li>
          <TextLink href="https://github.com/daidaniel">GitHub</TextLink>
        </li>
        <li>
          <TextLink href="https://www.linkedin.com/in/daidaniel">LinkedIn</TextLink>
        </li>
        <li>
          <TextLink href="mailto:danieldaiw@gmail.com">Email</TextLink>
        </li>
      </ul>
    </div>
    <a
      href="#more"
      aria-label="scroll down"
      class="absolute bottom-6 left-1/2 -translate-x-1/2 p-2 text-zinc-500 transition-colors [animation-delay:500ms] hover:text-amber-300 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-amber-300 motion-safe:animate-fade-up"
    >
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path
          d="M4 7.5 10 13.5 16 7.5"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </a>
  </Section>
  <Section id="more">
    <h2 class="text-2xl font-semibold">more soon</h2>
    <p class="mt-3 text-zinc-400">this spot is saved for a little experiment. check back in a bit.</p>
  </Section>
</Base>
