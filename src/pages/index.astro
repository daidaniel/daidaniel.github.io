---
import { Image } from "astro:assets";
import TextLink from "../components/TextLink.astro";
import Base from "../layouts/Base.astro";
import keyboard from "../assets/keyboard.svg";
import shadow from "../assets/shadow.svg";

const description =
  "Daniel Dai is a software engineer at Apple building AI-powered internal tooling. Previously at TikTok. UCLA computer science alum.";
---

<Base title="Daniel Dai — Software Engineer" description={description}>
  <!-- Below sm the keyboard keeps the size it has at the sm boundary (592px =
       640px viewport minus px-6) and the figure clips its right side, so the
       fixed-px long shadow stays proportional at every mobile width. The -mr-6
       bleeds the clip edge through main's right padding to the viewport edge.
       The mb calc cancels the transparent band under the keyboard's diagonal
       bottom edge (slope 1/3): band = 152px - width/3 (width = content width;
       the visible clip is width + 24px bleed), gone once the full keyboard fits. -->
  <figure
    class="relative motion-safe:animate-fade-up max-sm:-mr-6 max-sm:mb-[min(0px,33.333%_-_152px)] max-sm:overflow-x-clip md:translate-x-6"
  >
    <img
      class="long-shadow absolute inset-0 w-[592px] max-w-none sm:w-full"
      src={shadow.src}
      alt=""
    />
    <Image
      class="relative w-[592px] max-w-none sm:w-full"
      src={keyboard}
      alt="QK65 mechanical keyboard with white keycaps"
      loading="eager"
      fetchpriority="high"
    />
  </figure>
  <div class="md:-translate-x-6">
    <h1
      class="type-out mt-12 [--type-chars:10] text-[2.5rem] font-semibold leading-[1.1] sm:text-[3rem] md:text-[3.5rem]"
    >
      Daniel Dai
    </h1>
    <p
      class="mt-3 text-lg leading-[1.7] text-zinc-400 motion-safe:animate-fade-up [animation-delay:175ms]"
    >
      Software engineer at Apple
    </p>
    <p
      class="mt-6 text-pretty text-zinc-300 motion-safe:animate-fade-up [animation-delay:250ms]"
    >
      I build software across the stack—from AI-powered internal tools at Apple
      to Go microservices at TikTok serving millions of users. UCLA computer
      science alum, currently pursuing a master's at UIUC, with a passion for
      building simple, reliable software—and optimizing everything from
      developer workflows to custom keyboards.
    </p>
    <ul
      class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-4 sm:gap-x-7 motion-safe:animate-fade-up [animation-delay:325ms]"
      role="list"
    >
      <li>
        <a
          class="inline-block rounded bg-amber-300 px-5 py-2 font-semibold text-zinc-950 transition hover:-translate-y-0.5 hover:bg-amber-500 focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-amber-300 active:translate-y-0 sm:px-6"
          href="/DanielDai-Resume.pdf">Résumé</a
        >
      </li>
      <li>
        <TextLink href="https://github.com/daidaniel">GitHub</TextLink>
      </li>
      <li>
        <TextLink href="https://www.linkedin.com/in/daidaniel"
          >LinkedIn</TextLink
        >
      </li>
      <li>
        <TextLink href="mailto:danieldaiw@gmail.com">Email</TextLink>
      </li>
    </ul>
  </div>
</Base>
